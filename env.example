# ============================================================
#  .env  —  Advanced Mathematics Assistant Configuration
# ============================================================

# --- Groq LLM (free) ---
# Get key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# --- HuggingFace Embeddings (free) ---
# Get token at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=your_huggingface_token_here

# --- MongoDB (free tier) ---
# Get connection string at: https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DB_NAME=math_assistant
MONGODB_COLLECTION=chat_history

# --- Vector DB ---
# "chroma" (default) or "faiss"
VECTOR_DB_TYPE=chroma
CHROMA_PERSIST_DIR=./chroma_db
FAISS_INDEX_PATH=./faiss_index

# --- Model Config ---
LLM_MODEL=llama-3.3-70b-versatile 
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5

# --- App Config ---
APP_TITLE=Advanced Mathematics Assistant
DEBUG=False
